<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sidebar</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

  <style>
    body {
      background: #0f0f0f;
      font-family: 'Segoe UI', sans-serif;
    }

    /* Toggle Button */
    .sidebar-toggle-btn {
      position: fixed;
      top: 15px;
      left: 15px;
      z-index: 1050;
      background: linear-gradient(135deg, #00e5ff, #00bcd4);
      border: none;
      padding: 10px 14px;
      border-radius: 50%;
      box-shadow: 0 0 15px rgba(0,229,255,0.5);
      transition: 0.3s;
    }

    .sidebar-toggle-btn:hover {
      transform: scale(1.1);
      box-shadow: 0 0 25px rgba(0,229,255,0.8);
    }

    .sidebar-toggle-btn i {
      color: white;
      font-size: 20px;
    }

    /* Sidebar */
    .offcanvas-start {
      background: linear-gradient(160deg, #0f2027, #203a43, #2c5364);
      backdrop-filter: blur(12px);
      border-right: 1px solid rgba(255,255,255,0.1);
    }

    /* Header */
    .offcanvas-header {
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .offcanvas-title {
      font-weight: 600;
      font-size: 18px;
      color: #00e5ff;
      text-shadow: 0 0 10px rgba(0,229,255,0.6);
    }

    /* Menu */
    .menu-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      border-radius: 10px;
      margin-bottom: 8px;
      text-decoration: none;
      color: #ddd;
      transition: 0.3s ease;
      font-size: 15px;
    }

    .menu-item i {
      font-size: 18px;
      transition: 0.3s;
    }

    /* Hover */
    .menu-item:hover {
      background: rgba(255,255,255,0.08);
      color: #fff;
      transform: translateX(6px);
      box-shadow: 0 0 10px rgba(0,229,255,0.3);
    }

    .menu-item:hover i {
      transform: scale(1.2);
    }

    /* Active */
    .active-link {
      background: rgba(0,229,255,0.2);
      color: #00e5ff !important;
      box-shadow: 0 0 15px rgba(0,229,255,0.5);
    }

    /* Footer */
    .sidebar-footer {
      position: absolute;
      bottom: 10px;
      left: 20px;
      font-size: 12px;
      color: #aaa;
    }
  </style>
</head>

<body>

  <!-- Toggle -->
  <button class="sidebar-toggle-btn" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu">
    <i class="bi bi-grid"></i>
  </button>

  <!-- Sidebar -->
  <div class="offcanvas offcanvas-start text-light" tabindex="-1" id="sidebarMenu">

    <!-- Header -->
    <div class="offcanvas-header">
      <h5 class="offcanvas-title">📚 Book store</h5>
      <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
    </div>

    <!-- Menu -->
    <div class="offcanvas-body">

      <a href="/" class="menu-item active-link">
        <i class="bi bi-plus-circle"></i> Add Book
      </a>

      <a href="/showData" class="menu-item">
        <i class="bi bi-collection"></i> All Books
      </a>

    </div>

    <!-- Footer -->
    <div class="sidebar-footer">
      ⚡ book store Panel
    </div>

  </div>

  <!-- JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>